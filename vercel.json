{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/auth/(register|login)",
      "dest": "backend/vercel/auth.js"
    },
    {
      "src": "/api/products",
      "dest": "backend/vercel/products.js"
    },
    {
      "src": "/api/teams",
      "dest": "backend/vercel/teams.js"
    },
    {
      "src": "/api/posts/images",
      "dest": "backend/vercel/posts.js"
    },
    {
      "src": "/api/posts/([^/]+)",
      "dest": "backend/vercel/posts.js"
    },
    {
      "src": "/api/posts",
      "dest": "backend/vercel/posts.js"
    },
    {
      "src": "/api/orders/([^/]+)",
      "dest": "backend/vercel/orders.js"
    },
    {
      "src": "/api/orders",
      "dest": "backend/vercel/orders.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
