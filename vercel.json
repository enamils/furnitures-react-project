{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "functions": {
    "backend/vercel/*.js": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "/api/auth/(register|login)",
      "dest": "/backend/vercel/auth.js"
    },
    {
      "src": "/api/posts/(images|[^/]+)",
      "dest": "/backend/vercel/posts.js"
    },
    {
      "src": "/api/orders/([^/]+)",
      "dest": "/backend/vercel/orders.js"
    },
    {
      "src": "/api/(products|teams|posts|orders)",
      "dest": "/backend/vercel/$1.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    }
  ]
}
