{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "functions": {
    "backend/vercel/auth.js": {
      "runtime": "@vercel/node"
    },
    "backend/vercel/products.js": {
      "runtime": "@vercel/node"
    },
    "backend/vercel/teams.js": {
      "runtime": "@vercel/node"
    },
    "backend/vercel/posts.js": {
      "runtime": "@vercel/node"
    },
    "backend/vercel/orders.js": {
      "runtime": "@vercel/node"
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/(register|login)",
      "destination": "/backend/vercel/auth.js"
    },
    {
      "source": "/api/products",
      "destination": "/backend/vercel/products.js"
    },
    {
      "source": "/api/teams",
      "destination": "/backend/vercel/teams.js"
    },
    {
      "source": "/api/posts/images",
      "destination": "/backend/vercel/posts.js"
    },
    {
      "source": "/api/posts/(.*)",
      "destination": "/backend/vercel/posts.js"
    },
    {
      "source": "/api/posts",
      "destination": "/backend/vercel/posts.js"
    },
    {
      "source": "/api/orders/(.*)",
      "destination": "/backend/vercel/orders.js"
    },
    {
      "source": "/api/orders",
      "destination": "/backend/vercel/orders.js"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
